# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=agent_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password_here

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=36379
REDIS_PASSWORD=

# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key_here

# 阿里云百炼 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# MCP Server 配置
AGENT_MCP_LOCAL_ENABLED=false
AGENT_MCP_LOCAL_SERVER_URL=http://localhost:8090
AGENT_MCP_DASHSCOPE_WEBPARSER_ENABLED=true
AGENT_MCP_DASHSCOPE_WEBPARSER_SSE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/mcps/WebParser/sse
AGENT_MCP_DASHSCOPE_ZIMAGE_ENABLED=true
AGENT_MCP_DASHSCOPE_ZIMAGE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/zimage/mcp
AGENT_MCP_DASHSCOPE_WEATHER_ENABLED=true
AGENT_MCP_DASHSCOPE_WEATHER_URL=https://dashscope.aliyuncs.com/api/v1/mcps/mcp-OWQ3Njc0M2FlY2Ji/mcp
AGENT_MCP_OLLAMA_ENABLED=false
AGENT_MCP_OLLAMA_SERVER_URL=http://localhost:11434

# JPA 配置
JPA_DDL_AUTO=update

# Memory 配置
AGENT_MEMORY_TWO_TIER_ENABLED=true
AGENT_MEMORY_STM_MAX_MESSAGES=20
AGENT_MEMORY_STM_TTL_MINUTES=120
AGENT_MEMORY_LTM_ENABLED=true
AGENT_MEMORY_LTM_SUMMARIZER=llm
AGENT_MEMORY_LTM_THRESHOLD=10

# RAG 配置
AGENT_RAG_ENABLED=true
AGENT_RAG_TOP_K=4
AGENT_RAG_SIMILARITY_THRESHOLD=0.2
AGENT_RAG_REWRITE_WITH_HISTORY=true

# Planning 配置
AGENT_PLANNING_ENABLED=true
AGENT_PLANNING_STRATEGY=llm
AGENT_PLANNING_ALLOW_REPLAN=true
AGENT_PLANNING_MAX_REPLAN=2
AGENT_PLANNING_MAX_STEPS=10

# Intent 配置
AGENT_INTENT_ENABLED=true
AGENT_INTENT_USE_LLM=true
